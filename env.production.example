# Docker 一键部署配置示例
# 推荐直接使用 ./deploy.sh 自动生成 .env。
# 如需手动部署：复制 .env.example 为 .env 后执行 docker compose --env-file .env up -d --build。

# MySQL 只在 docker compose 内网暴露，不映射到宿主机端口。
# 下列密钥留空时 docker compose 会拒绝启动；推荐使用 ./deploy.sh 自动生成。
MYSQL_ROOT_PASSWORD=
MYSQL_DATABASE=duanshipin
MYSQL_USER=duanshipin
MYSQL_PASSWORD=

# 宿主机访问端口
BACKEND_BIND_HOST=127.0.0.1
BACKEND_PORT=4000
FRONTEND_PORT=4001

# 可选：构建镜像时使用的 npm 源。默认使用官方源；网络不佳时可改为可访问的镜像源。
NPM_REGISTRY=https://registry.npmjs.org/

# 可选：使用预构建镜像部署时填写，配合 deploy-prebuilt.sh 使用。
BACKEND_IMAGE=
FRONTEND_IMAGE=

# 生产环境必须使用随机强密钥，建议 32 字节以上。
JWT_SECRET=
ENCRYPTION_KEY=

# 大模型 API Key 由管理员在前端系统设置中配置并激活，不放在环境变量中。
