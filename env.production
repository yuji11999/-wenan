# 生产环境配置文件
# 请根据实际情况修改以下配置

# JWT 密钥（生产环境请务必修改为复杂的随机字符串）
JWT_SECRET=your-production-jwt-secret-key-change-this-to-random-string-2024

# OpenAI 配置（可选，如果不使用可以留空，在前端系统设置中配置）
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-3.5-turbo

# 注意：数据库配置已在 docker-compose.yml 中硬编码
# DATABASE_URL=mysql://duanshipin:KEpYWdYx3TXDhrk3@host.docker.internal:3306/duanshipin



