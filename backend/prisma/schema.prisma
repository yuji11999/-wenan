generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id             String          @id @default(uuid())
  username       String          @unique
  password       String
  role           String          @default("user")
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  status         String          @default("pending")
  // 登录安全相关字段
  loginAttempts  Int             @default(0)        // 登录失败次数
  lockedUntil    DateTime?                          // 锁定到期时间
  lastLoginAt    DateTime?                          // 最后登录时间
  lastLoginIp    String?                            // 最后登录IP
  copywritings   Copywriting[]
  aiConfigs      AIConfig[]
  loginLogs      LoginLog[]                         // 登录日志
  userSessions   UserSession[]                      // 用户会话

  @@map("users")
}

model Copywriting {
  id               String                @id @default(uuid())
  userId           String
  title            String
  content          String                @db.Text
  videoUrl         String?
  industry         String
  status           String                @default("draft")
  sourceType       String                @default("original")
  sourceId         String?
  isSystemMaterial Boolean               @default(false)
  isPublic         Boolean               @default(false)
  shareStatus      String                @default("none")
  viewCount        Int                   @default(0)
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  analysis         CopywritingAnalysis?
  children         CopywritingRelation[] @relation("ChildCopywriting")
  relations        CopywritingRelation[] @relation("ParentCopywriting")
  user             User                  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([sourceType])
  @@index([industry])
  @@index([isSystemMaterial])
  @@index([isPublic])
  @@index([shareStatus])
  @@map("copywritings")
}

model CopywritingAnalysis {
  id              String      @id @default(uuid())
  copywritingId   String      @unique
  originalText    String      @db.Text
  topic           String
  topicPosition   Json?
  hook            String
  hookPosition    Json?
  goldenSentence  String
  goldenPosition  Json?
  adPlacement     String
  adPosition      Json?
  analysisContent String      @db.Text
  contentPosition Json?
  tags            Json
  industry        String
  aiConfidence    Json?
  isModified      Boolean     @default(false)
  modifiedFields  Json?
  version         Int         @default(1)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  copywriting     Copywriting @relation(fields: [copywritingId], references: [id], onDelete: Cascade)

  @@index([copywritingId])
  @@map("copywriting_analyses")
}

model CopywritingRelation {
  id              String      @id @default(uuid())
  parentId        String
  childId         String
  relationType    String
  rewriteStrategy String?
  revisionType    String?
  isExternalRef   Boolean     @default(false)
  externalRefText String?     @db.Text
  createdAt       DateTime    @default(now())
  child           Copywriting @relation("ChildCopywriting", fields: [childId], references: [id], onDelete: Cascade)
  parent          Copywriting @relation("ParentCopywriting", fields: [parentId], references: [id], onDelete: Cascade)

  @@index([parentId])
  @@index([childId])
  @@index([relationType])
  @@map("copywriting_relations")
}

model ViralAnalysis {
  id                     String   @id @default(uuid())
  copywritingId          String   @unique
  overallScore           Int
  topicHeat              Int
  hookStrength           Int
  emotionResonance       Int
  spreadPotential        Int
  conversionPower        Int
  fireReasons            Json
  improvementSuggestions Json
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  @@index([overallScore])
  @@map("viral_analyses")
}

model Material {
  id         String   @id @default(uuid())
  type       String
  content    String   @db.Text
  usageCount Int      @default(0)
  heatScore  Int      @default(0)
  createdAt  DateTime @default(now())

  @@index([type])
  @@index([heatScore])
  @@map("materials")
}

model Trending {
  id       String   @id @default(uuid())
  type     String
  content  String
  rank     Int
  industry String
  date     DateTime @default(now())

  @@index([type])
  @@index([industry])
  @@index([date])
  @@map("trendings")
}

model Category {
  id        String   @id @default(uuid())
  name      String   @unique
  value     String   @unique
  sortOrder Int      @default(0)
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([sortOrder])
  @@map("categories")
}

/// 通用系统设置表,用于存储提示词等键值配置
model Setting {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([key])
  @@map("settings")
}

/// AI配置表，用于存储用户的AI服务配置
model AIConfig {
  id           String   @id @default(uuid())
  userId       String
  provider     String   // openai, qwen, wenxin, zhipu, deepseek, gemini
  providerName String   // 显示名称
  model        String   // 模型名称
  modelName    String   // 模型显示名称
  apiKey       String   @db.Text // API密钥（加密存储）
  baseUrl      String   // API地址
  isActive     Boolean  @default(false) // 是否为当前激活配置
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([provider])
  @@map("ai_configs")
}

/// 登录日志表，记录所有登录尝试
model LoginLog {
  id          String   @id @default(uuid())
  userId      String?                           // 用户ID（登录失败时可能为空）
  username    String                            // 尝试登录的用户名
  ipAddress   String                            // 登录IP地址
  userAgent   String?                           // 用户代理
  success     Boolean                           // 是否成功
  failReason  String?                           // 失败原因
  createdAt   DateTime @default(now())
  user        User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([username])
  @@index([ipAddress])
  @@index([success])
  @@index([createdAt])
  @@map("login_logs")
}

/// 用户会话表，用于会话管理和强制登出
model UserSession {
  id          String   @id @default(uuid())
  userId      String
  token       String   @unique                   // JWT token或session token
  ipAddress   String                            // 登录IP
  userAgent   String?                           // 用户代理
  isActive    Boolean  @default(true)           // 是否活跃
  lastUsed    DateTime @default(now())          // 最后使用时间
  expiresAt   DateTime                          // 过期时间
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@index([isActive])
  @@index([expiresAt])
  @@map("user_sessions")
}
